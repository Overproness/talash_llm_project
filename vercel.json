{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "http://localhost:5100/api/:path*"
        }
    ],
    "experimentalServices": {
        "frontend": {
            "installCommand": "npm install",
            "buildCommand": "npm run build",
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "nextjs"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/api"
        }
    }
}